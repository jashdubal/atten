#!/bin/bash

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

if command -v uv >/dev/null 2>&1; then
    uv run cli.py "$@"
elif command -v python3 >/dev/null 2>&1; then
    python3 cli.py "$@"
else
    echo "Error: Neither 'uv' nor 'python3' is available in your PATH." >&2
    exit 1
fi
