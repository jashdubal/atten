#!/bin/bash

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "Atten development setup requires macOS." >&2
    exit 1
fi
if ! xcode-select -p >/dev/null 2>&1; then
    echo "Install Xcode Command Line Tools with: xcode-select --install" >&2
    exit 1
fi
if ! command -v uv >/dev/null 2>&1; then
    echo "Install uv from https://docs.astral.sh/uv/ and rerun this command." >&2
    exit 1
fi

echo "> SYNCING_LOCKED_PYTHON_3.12_ENVIRONMENT"
uv python install 3.12
uv sync --frozen

echo "> VERIFYING_BACKEND"
uv run python cli.py --list-voices --json >/dev/null

echo "ATTEN_DEVELOPMENT_BACKEND: READY"
echo "Launch the app with: bin/atten"
echo "The first development synthesis downloads the pinned-compatible Kokoro model."
